# Copy to `.env` for local development. Do not commit real secrets.

# Cloud AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
INSIGHT_OPENAI_MODEL=gpt-4.1-mini
INSIGHT_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
BASE_CV_OPENAI_MODEL=gpt-4.1-mini

# Local AI/runtime endpoints
INSIGHT_OLLAMA_URL=http://127.0.0.1:11434/api/generate
INSIGHT_OLLAMA_MODEL=llava:latest
OLLAMA_HOST=
CVOPS_COMFY_URL=http://127.0.0.1:8188
CVOPS_TRELLIS_APPLE_URL=http://127.0.0.1:8082
